{
  "name": "wordsnap",
  "version": "1.0.0",
  "description": "Cross-browser popup translation extension for English learning",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode chrome",
    "dev:firefox": "vite build --watch --mode firefox",
    "build": "npm run typecheck && npm run build:chrome:bundle && npm run build:firefox:bundle",
    "bundle": "node scripts/bundle.mjs",
    "build:chrome": "npm run typecheck && npm run build:chrome:bundle",
    "build:chrome:bundle": "vite build --mode chrome",
    "build:firefox": "npm run typecheck && npm run build:firefox:bundle",
    "build:firefox:bundle": "vite build --mode firefox",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "crx": "^5.0.1",
    "eslint": "^8.57.0",
    "terser": "^5.47.1",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "dexie": "^4.0.0"
  }
}
